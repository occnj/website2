# Public browser configuration. The anon key is visible by design; RLS is mandatory.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets. Never prefix these with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM=Oasis Website <noreply@example.org>

# Canonical origin used for metadata, robots, and sitemap.
NEXT_PUBLIC_SITE_URL=https://example.org
